{
  "extends": "@repo/typescript-config/nextjs.json",

  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "allowJs": true,
    "skipLibCheck": true,

    "paths": {
      "@/*": ["./*"],
      "~/*": ["./*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],

  "exclude": ["node_modules"]
}
